# Only needed if you want to push from your laptop with the devto-cli instead of
# (or in addition to) the GitHub Action. Copy this file to `.env` and fill in.
# `.env` is gitignored — never commit your real token.
DEVTO_TOKEN=your_devto_api_key_here
# Optional: usually auto-detected from your git `origin` remote.
# DEVTO_REPO=davisethan/devto-posts
# DEVTO_BRANCH=main
